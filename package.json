{
  "name": "womanhoodofwubz.com",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Womanhood of Wubz",
  "homepage": "https://womanhoodofwubz.neocities.org/",
  "scripts": {
    "__c0": "====================[ Build & Development ]======================",
    "start": "yarn dev",
    "dev": "vite --open",
    "build": "vite build",
    "preview": "yarn build && vite preview --open",
    "preview:ci": "vite preview --strictPort",
    "__c1": "====================[ Linting & Type Checking ]==================",
    "lint": "yarn lint:fix && yarn ts:check && yarn pw:ts:check",
    "lint:fix": "npx biome check . --fix",
    "ts:check": "tsc",
    "pw:ts:check": "tsc --project playwright/tsconfig.json",
    "__c2": "====================[ Playwright Testing ]=======================",
    "test:e2e": "yarn pw:run --project=e2e",
    "test:a11y": "yarn pw:run --project=a11y --project=a11y:mobile",
    "test:lighthouse": "yarn pw:run --project=lighthouse",
    "test:lighthouse:production": "yarn pw:run --project=lighthouse:production",
    "pw:run": "playwright test",
    "pw:open": "playwright test --ui",
    "pw:report": "playwright show-report playwright/results/html"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bvandercar-vt/womanhoodofwubz.com"
  },
  "keywords": [
    "bass",
    "music"
  ],
  "author": "Blake Vandercar",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bvandercar-vt/womanhoodofwubz.com/issues"
  },
  "dependencies": {
    "@fontsource/outfit": "^5",
    "@fortawesome/fontawesome-svg-core": "^7",
    "@fortawesome/free-brands-svg-icons": "^7",
    "@fortawesome/free-solid-svg-icons": "^7",
    "@fortawesome/react-fontawesome": "^3",
    "classnames": "^2",
    "contentful": "^11",
    "es-toolkit": "^1",
    "merge-refs": "^2",
    "react": "^18",
    "react-dom": "^18",
    "react-modal": "^3.16"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4",
    "@biomejs/biome": "2.3",
    "@playwright/test": "^1",
    "@tailwindcss/vite": "^4",
    "@types/node": "^24",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-modal": "^3",
    "@vitejs/plugin-react": "^6",
    "axe-core": "^4",
    "dotenv": "^16",
    "lighthouse": "^13",
    "playwright-lighthouse": "^4",
    "tailwindcss": "^4.3",
    "type-fest": "^5",
    "typescript": "^7",
    "vite": "^8"
  }
}
